[project]
name = "tottok-cli"
version = "0.1.0"
description = "tottok MCP メモリーサーバの CLI runtime (Claude Code plugin から ~/.tottok/cli/ に展開される)"
requires-python = ">=3.11"
dependencies = [
    # MCP HTTP transport クライアント
    "mcp>=1.0.0",
    # SinglePassResult 等のスキーマ検証
    "pydantic>=2.9.0",
    # CLI エントリポイント
    "typer>=0.12.0",
    # 出力整形 (table / json / colored output)
    "rich>=13.0.0",
]

[tool.uv]
package = false

[tool.hatch.build.targets.wheel]
packages = ["cli", "tottok_core"]
